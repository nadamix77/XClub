generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tweet {
  id          String   @id @default(cuid())
  content     String
  authorName  String
  status      String   @default("pending") // pending | approved | rejected | posted | failed
  flagReason  String?  // reason it was flagged as suspicious
  postedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
